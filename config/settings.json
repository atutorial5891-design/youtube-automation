{
  "app": {
    "name": "YouTube Automation",
    "version": "1.0.0",
    "env": "development"
  },
  "api": {
    "deepseek": {
      "model": "deepseek-chat",
      "temperature": 0.7,
      "max_tokens": 500
    },
    "chatgpt": {
      "model": "gpt-4o-mini",
      "temperature": 0.8,
      "max_tokens": 800
    },
    "claude": {
      "model": "claude-3-5-sonnet-latest",
      "temperature": 0.8,
      "max_tokens": 800
    },
    "youtube": {
      "max_upload_size_gb": 128,
      "publish_schedule": "daily_3x"
    }
  },
  "system": {
    "max_retries": 3,
    "max_videos_per_day": 7,
    "agent_accuracy_threshold": 0.8
  },
  "hybrid_generation": {
    "deepseek_topic_usd": 0.015,
    "deepseek_outline_usd": 0.025,
    "chatgpt_script_usd": 0.125
  },
  "orchestrator": {
    "default_topic": "Why small habits compound faster than big goals",
    "default_category": "general",
    "log_level": "INFO",
    "verbose": false,
    "video_output_relative": "data/videos",
    "placeholder_video_basename": "stage2_placeholder.mp4",
    "placeholder_tone": "engaging",
    "placeholder_agent_pass": true,
    "placeholder_script_template": "[HOOK]\nGrab attention on: {topic}\n\n[BODY]\nCategory: {category}. Placeholder script for pipeline wiring.\n\n[OUTRO]\nSubscribe for more."
  }
}
